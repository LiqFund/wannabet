generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bet {
  id             String       @id @default(cuid())
  title          String
  description    String
  templateType   String
  assetBase      String
  assetQuote     String
  threshold      Decimal?
  lowerBound     Decimal?
  upperBound     Decimal?
  resolveAt      DateTime
  stakePerSide   Decimal
  currencyLabel  String
  creatorAddress String
  takerAddress   String?
  status         String       @default("OPEN")
  outcome        String       @default("UNRESOLVED")
  xCreatorHandle String?
  xOpponentHandle String?
  handlesPublic  Boolean      @default(false)
  oracleSource   String       @default("Simulated oracle metadata")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  resolution     Resolution?
}

model Resolution {
  id          String   @id @default(cuid())
  betId       String   @unique
  bet         Bet      @relation(fields: [betId], references: [id], onDelete: Cascade)
  resolvedAt  DateTime
  oracleValue Decimal?
  notes       String
}
